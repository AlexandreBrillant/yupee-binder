{
  "name": "yupee-binder",
  "version": "1.0.0",
  "description": "Create simple UI composants from a JSON format and synchronize it automatically",
  "keywords": [
    "yupee",
    "javascript binder",
    "javascript form",
    "javascript mapper",
    "javascript field",
    "javascript interface"
  ],
  "homepage": "https://github.com/AlexandreBrillant/yupee-binder#readme",
  "bugs": {
    "url": "https://github.com/AlexandreBrillant/yupee-binder/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlexandreBrillant/yupee-binder.git"
  },
  "license": "ISC",
  "author": "Alexandre Brillant",
  "type": "commonjs",
  "main": "yupee-binder.js",
  "scripts": {
    "build:clean": "rm -rf dist && mkdir dist",
    "build:copy": "cp src/yupee-binder.js dist",
    "build:esm" : "node tools/preprocessor.js -i src/yupee-binder.mjs -o dist/yupee-binder.mjs",
    "build:minify": "terser ./src/yupee-binder.js -o ./dist/yupee-binder.min.js && terser ./dist/yupee-binder.mjs -o ./dist/yupee-binder.min.mjs",
    "build": "npm run build:clean && npm run build:copy && npm run build:esm && npm run build:minify",
    "prebuild": "node --check src/yupee-binder.js"
  },
  "dependencies": {
    "terser": "^5.46.0"
  }
}
